# Production Environment Configuration
# Copy this file to .env and update with your production values

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
POSTGRES_DB=sophia
POSTGRES_USER=sophia_user
POSTGRES_PASSWORD=CHANGE_THIS_TO_SECURE_PASSWORD
POSTGRES_HOST=db
POSTGRES_PORT=5432

# =============================================================================
# TELEGRAM BOT CONFIGURATION
# =============================================================================
# Get your bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=1234567890:ABCDEFGHIJKLMNOPQRSTUVWXYZ123456789
TELEGRAM_BOT_USERNAME=your_bot_username

# =============================================================================
# API CONFIGURATION
# =============================================================================
# Base URL for your production domain
API_BASE_URL=https://your-domain.com
API_PORT=8055

# Admin password for frontend access
FRONTEND_PASSWORD=CHANGE_THIS_TO_SECURE_ADMIN_PASSWORD

# =============================================================================
# FRONTEND CONFIGURATION
# =============================================================================
# Must match API_BASE_URL
VITE_API_BASE_URL=https://your-domain.com
VITE_FRONTEND_PASSWD=CHANGE_THIS_TO_SECURE_ADMIN_PASSWORD

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================
# Generate a secure random string for JWT secrets
JWT_SECRET_KEY=CHANGE_THIS_TO_SECURE_RANDOM_STRING

# =============================================================================
# PRODUCTION OPTIMIZATIONS
# =============================================================================
# Set to production for optimized builds
NODE_ENV=production
PYTHON_ENV=production

# =============================================================================
# MONITORING & LOGGING
# =============================================================================
# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Enable/disable debug mode
DEBUG=false

# =============================================================================
# BACKUP CONFIGURATION
# =============================================================================
# Database backup settings
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *  # Daily at 2 AM
BACKUP_RETENTION_DAYS=30

# =============================================================================
# SSL/TLS CONFIGURATION
# =============================================================================
# SSL certificate paths (if using custom certificates)
SSL_CERT_PATH=/path/to/cert.pem
SSL_KEY_PATH=/path/to/key.pem

# =============================================================================
# RATE LIMITING
# =============================================================================
# API rate limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# Bot rate limiting
BOT_RATE_LIMIT_MESSAGES=30
BOT_RATE_LIMIT_WINDOW=60

# =============================================================================
# FEATURE FLAGS
# =============================================================================
# Enable/disable features
ENABLE_USER_REGISTRATION=true
ENABLE_MATCHING=true
ENABLE_FEEDBACK=true
ENABLE_THANKS=true

# =============================================================================
# EXTERNAL SERVICES
# =============================================================================
# Optional: External monitoring service
MONITORING_ENDPOINT=
MONITORING_API_KEY=

# Optional: Email service for notifications
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=

# =============================================================================
# DEPLOYMENT INFO
# =============================================================================
# Deployment environment
DEPLOYMENT_ENV=production
DEPLOYMENT_VERSION=latest
DEPLOYMENT_DATE=2024-01-01

# =============================================================================
# INSTRUCTIONS
# =============================================================================
# 1. Copy this file to .env in the infra/ directory
# 2. Replace all "CHANGE_THIS" values with secure, production values
# 3. Update domain names and URLs to match your production setup
# 4. Generate secure passwords and tokens
# 5. Configure SSL certificates if using HTTPS
# 6. Test the configuration before deploying



















